---
const equipamentos = [
  {
    nome: 'Laser Therapy EC',
    categoria: 'Laser Terapêutico',
    desc: 'Equipamento de laser de alta performance para tratamentos com máximo conforto, eficácia comprovada e recuperação rápida.',
    img: '/media/equipamentos/laser-therapy-ec.webp',
    imgAlt: 'Laser Therapy EC',
  },
  {
    nome: 'Elite DUO',
    categoria: 'Clareamento & Fototerapia',
    desc: 'Aparelho de última geração para clareamento dental e fototerapia — resultados superiores com protocolo seguro e confortável.',
    img: '/media/equipamentos/elite-duo.webp',
    imgAlt: 'Elite DUO',
  },
  {
    nome: 'Scanner Intraoral',
    categoria: 'Diagnóstico Digital 3D',
    desc: 'Mapeamento digital da cavidade oral em alta precisão para um planejamento verdadeiramente personalizado — sem moldagens, com mais conforto.',
    img: '/media/equipamentos/scanner-intraoral.webp',
    imgAlt: 'Scanner Intraoral 3D',
  },
];
---

<section class="relative bg-parchment pt-48 pb-32 md:py-40 overflow-hidden">

  <!-- Número decorativo -->
  <div aria-hidden="true" data-deco="06" class="absolute top-8 right-8 font-display text-[7rem] md:text-[11rem] leading-none select-none pointer-events-none font-light" style="color: #CCCAD8"></div>

  <div class="max-w-7xl mx-auto px-8 md:px-12">

    <!-- Cabeçalho -->
    <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-20 mb-20">
      <div data-reveal="left">
        <div class="rule">Tecnologia & Equipamentos</div>
      </div>
      <div data-reveal>
        <h2
          class="font-display font-light"
          style="font-size: clamp(1.7rem, 3.2vw, 2.9rem); line-height: 1.1; max-width: 620px; color: var(--ink)"
        >
          Precisão e conforto em cada
          <em style="font-style:italic; color: var(--terra)"> procedimento.</em>
        </h2>
      </div>
    </div>

    <!-- Texto introdutório -->
    <div class="mb-16 max-w-2xl" data-reveal>
      <p class="text-[0.9rem] leading-relaxed" style="color: var(--muted)">
        A clínica conta com tecnologia de ponta para garantir diagnósticos mais precisos, procedimentos mais seguros e uma experiência mais confortável para cada paciente.
      </p>
    </div>

    <!-- Cards de equipamentos com foto -->
    <div class="grid md:grid-cols-3 gap-0" style="border-top: 1px solid rgba(201,168,60,0.2)">
      {equipamentos.map((eq, i) => (
        <div
          class="flex flex-col py-10 group cursor-default"
          style={`
            border-bottom: 1px solid rgba(201,168,60,0.2);
            border-right: ${i < equipamentos.length - 1 ? '1px solid rgba(201,168,60,0.18)' : 'none'};
            padding-left: ${i === 0 ? '0' : '2rem'};
            padding-right: ${i === equipamentos.length - 1 ? '0' : '2rem'};
            transition-delay:${i * 0.1}s
          `}
          data-reveal
        >
          <!-- Foto do equipamento -->
          <div
            class="mb-6 flex items-center justify-center"
            style="height: 260px; background: #ffffff; padding: 1.5rem;"
          >
            {eq.img ? (
              <img
                src={eq.img}
                alt={eq.imgAlt}
                class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-700"
                style="max-height: 100%;"
              />
            ) : (
              <!-- Placeholder enquanto fotos não chegam -->
              <div class="w-full h-full flex flex-col items-center justify-center gap-3" style="background: #E8E4D9; color: rgba(125,100,60,0.4)">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span class="text-[0.58rem] tracking-widest uppercase">foto em breve</span>
              </div>
            )}
          </div>

          <!-- Categoria -->
          <p class="text-[0.6rem] tracking-[0.2em] uppercase mb-2" style="color: var(--terra)">
            {eq.categoria}
          </p>

          <!-- Nome do equipamento -->
          <h3
            class="font-display font-light mb-3 transition-colors duration-300"
            style="font-size: 1.2rem; line-height: 1.2; color: var(--ink)"
          >
            {eq.nome}
          </h3>

          <!-- Descrição -->
          <p class="text-[0.82rem] leading-relaxed" style="color: var(--muted)">
            {eq.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- Detalhe tipográfico -->
    <div class="mt-16 pl-5" style="border-left: 2px solid var(--terra)" data-reveal>
      <p class="font-display italic font-light leading-snug" style="color: var(--terra); font-size: 1.1rem">
        "Cada detalhe pensado para oferecer a melhor experiência."
      </p>
    </div>
  </div>
</section>

<style>
  .group:hover h3 { color: var(--terra) !important; }
</style>
