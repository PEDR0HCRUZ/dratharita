---
const itens = [
  'Atendimento individualizado',
  'Planejamento personalizado para o seu rosto',
  'Resultados naturais e duradouros',
  'Acompanhamento após o procedimento',
  'Clínica moderna no coração de Florianópolis',
  'Parcelamento disponível',
];
---

<section class="relative pt-48 pb-32 md:py-40 overflow-hidden" style="background: #0D1830">

  <!-- Número decorativo -->
  <div
    aria-hidden="true"
    data-deco="07"
    class="absolute top-8 left-8 font-display text-[7rem] md:text-[11rem] leading-none select-none pointer-events-none font-light"
    style="color: #182448"
  ></div>

  <div class="relative max-w-7xl mx-auto px-8 md:px-12">
    <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-20">

      <!-- Label -->
      <div data-reveal="left">
        <div class="rule" style="color: var(--clay)">Por que escolher</div>
      </div>

      <!-- Conteúdo -->
      <div>
        <h2
          class="font-display font-light mb-16"
          style="font-size: clamp(1.7rem, 3.2vw, 2.9rem); line-height: 1.1; max-width: 660px; color: #ffffff"
          data-reveal
        >
          Um atendimento pensado para você —
          <em style="font-style:italic; color: var(--clay)"> do início ao fim.</em>
        </h2>

        <!-- Lista em grid de duas colunas com linha entre cada item -->
        <div
          class="grid md:grid-cols-2 border-t"
          style="border-color: rgba(245,243,239,0.1); transition-delay:0.15s"
          data-reveal
        >
          {itens.map((item, i) => (
            <div
              class={`flex items-center gap-5 py-7 border-b ${i % 2 !== 0 ? 'md:border-l md:pl-10' : ''} group`}
              style={`border-color: rgba(245,243,239,0.1); transition-delay:${0.1 + (i * 0.06)}s`}
              data-reveal
            >
              <!-- Tick animado -->
              <span
                class="tick-box flex-shrink-0 w-5 h-5 flex items-center justify-center border transition-colors duration-300"
                style="border-color: rgba(201,168,60,0.35)"
              >
                <svg
                  width="8" height="6" viewBox="0 0 8 6" fill="none"
                  class="tick-icon transition-colors duration-300"
                  style="color: rgba(201,168,60,0.55)"
                >
                  <path d="M1 3l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span
                class="item-label text-[0.87rem] transition-colors duration-300"
                style="color: rgba(245,243,239,0.65)"
              >
                {item}
              </span>
            </div>
          ))}
        </div>

        <div class="mt-12" data-reveal style="transition-delay:0.5s">
          <a href="#agendar" class="btn-cta btn-cta--light">
            <span class="btn-cta__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
              </svg>
            </span>
            Agendar minha avaliação
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .group:hover .tick-box { border-color: var(--clay) !important; }
  .group:hover .tick-icon { color: var(--clay) !important; }
  .group:hover .item-label { color: var(--cream) !important; }
</style>
