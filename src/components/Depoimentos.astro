---
const dep = [
  { nome: 'Ana Paula M.', cidade: 'Florianópolis, SC', texto: 'O resultado foi exatamente o que eu queria: natural, sutil, mas com uma diferença enorme na minha autoestima. Me sinto mais eu mesma.' },
  { nome: 'Camila R.',    cidade: 'Florianópolis, SC', texto: 'Atendimento acolhedor do início ao fim. A Dra. Tharita explicou tudo com muita paciência e o resultado superou minhas expectativas.' },
  { nome: 'Fernanda S.',  cidade: 'São José, SC',       texto: 'Tinha muito medo de parecer "artificial" — mas o resultado foi tão natural que só eu sei que fiz. Recomendo sem hesitar.' },
  { nome: 'Mariana T.',   cidade: 'Florianópolis, SC', texto: 'A clínica é linda, o ambiente é acolhedor e a profissional é incrível. Me senti segura durante todo o processo.' },
  { nome: 'Juliana B.',   cidade: 'Palhoça, SC',        texto: 'Fiz as lentes de contato dental e fiquei encantada! Sorriso mais bonito e harmônico, sem exageros. Exatamente o que eu pedia.' },
  { nome: 'Lívia C.',     cidade: 'Florianópolis, SC', texto: 'Profissional extremamente competente e delicada. O planejamento foi feito pensando no meu rosto, não em um padrão genérico.' },
];

// Duplicamos para o marquee infinito
const all = [...dep, ...dep];
---

<section id="depoimentos" class="relative py-32 md:py-40">

  <div class="max-w-7xl mx-auto px-8 md:px-12 mb-16">
    <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-20 items-end">
      <div data-reveal="left">
        <div class="rule">Depoimentos</div>
      </div>
      <div data-reveal>
        <h2
          class="font-display font-light"
          style="font-size: clamp(1.7rem, 3.2vw, 2.9rem); line-height: 1.1; max-width: 620px; color: var(--ink)"
        >
          O que as
          <em style="font-style:italic; color: var(--terra)"> pacientes dizem</em>
        </h2>
        <p class="text-sm mt-3 tracking-wide" style="color: var(--muted)">Avaliações verificadas · Google Meu Negócio</p>
      </div>
    </div>
  </div>

  <!-- Marquee de cards -->
  <div class="overflow-hidden" data-reveal style="transition-delay:0.2s">
    <div class="animate-marquee gap-5 flex">
      {all.map((d) => (
        <article
          class="flex-shrink-0 w-[320px] md:w-[380px] border p-8 flex flex-col gap-6"
          style="background: var(--cream); border-color: var(--warm)"
          style="cursor: default"
        >
          <!-- Aspas decorativas -->
          <div class="font-display text-6xl font-light leading-none select-none" style="color: rgba(168,136,40,0.2)">"</div>

          <!-- Texto -->
          <p class="text-[0.87rem] leading-relaxed flex-1 -mt-4" style="color: rgba(29,47,98,0.8)">
            {d.texto}
          </p>

          <!-- Estrelas + autor -->
          <div class="flex flex-col gap-3 pt-4 border-t" style="border-color: var(--warm)">
            <div class="text-xs tracking-wider" style="color: var(--terra)">★ ★ ★ ★ ★</div>
            <div class="flex items-center gap-3">
              <div
                class="w-8 h-8 flex items-center justify-center font-display text-sm font-light text-cream"
                style="background: var(--terra)"
              >
                {d.nome[0]}
              </div>
              <div>
                <p class="text-[0.8rem] font-medium" style="color: var(--ink)">{d.nome}</p>
                <p class="text-[0.68rem] tracking-wide" style="color: var(--muted)">{d.cidade}</p>
              </div>
              <!-- Google mark -->
              <div class="ml-auto opacity-40">
                <svg width="16" height="16" viewBox="0 0 24 24">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
