---
const servicos = [
  {
    num: '01',
    nome: 'Harmonização\nOrofacial',
    desc: 'Além de Toxina Botulínica, Preenchedores e Bioestimuladores de Colágeno, sou especialista em Estética Regenerativa da Face e Pescoço — a abordagem mais moderna da medicina estética. Diferente de apenas preencher, a estética regenerativa trata a pele de dentro para fora, devolvendo saúde, firmeza e um aspecto mais natural ao rosto. Utilizo técnicas que estimulam a bioestimulação tecidual, promovendo regeneração celular e melhora global da qualidade da pele.',
    tag: 'Resultado que ninguém percebe, mas todos notam.',
    img: '/media/86EFBD6B-5546-40EF-99CC-FE8A773B4044_1_105_c.webp',
    imgAlt: 'Harmonização Orofacial',
    imgPos: 'center 25%',
  },
  {
    num: '02',
    nome: 'Lentes de\nContato Dental',
    desc: 'Transforme o seu sorriso com dentes mais brancos, alinhados e harmônicos — preservando o que faz o seu sorriso ser único.',
    tag: 'Lentes que realçam a beleza sem perder a essência.',
    img: '/media/lentes.webp',
    imgAlt: 'Lentes de Contato Dental',
  },
  {
    num: '03',
    nome: 'Ortodontia\npara Adultos',
    desc: 'Alinhe os dentes com planejamento estético e funcional — com discrição, conforto e um resultado que combina com você.',
    tag: 'Seu sorriso alinhado, do jeito que sempre imaginou.',
    img: '/media/IMG_4882.webp',
    imgAlt: 'Ortodontia para Adultos',
  },
];
---

<section id="servicos" class="relative bg-parchment pt-48 pb-32 md:pt-32 md:pb-40 overflow-hidden">

  <!-- Número decorativo -->
  <!-- fundo parchment (#EDE7D9) → tom ligeiramente mais escuro -->
  <div aria-hidden="true" data-deco="03" class="absolute top-8 right-8 font-display text-[7rem] md:text-[11rem] leading-none select-none pointer-events-none font-light" style="color: #CCCAD8"></div>

  <div class="max-w-7xl mx-auto px-8 md:px-12">

    <!-- Cabeçalho -->
    <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-20 mb-20 items-end">
      <div data-reveal="left">
        <div class="rule">Serviços</div>
      </div>
      <div data-reveal>
        <h2
          class="font-display font-light"
          style="font-size: clamp(1.7rem, 3.2vw, 2.9rem); line-height: 1.1; letter-spacing: -0.01em; max-width: 700px; color: var(--ink)"
        >
          Da face ao sorriso: planejamento completo com
          <em style="font-style: italic; color: var(--terra)"> equilíbrio, elegância</em> e naturalidade.
        </h2>
      </div>
    </div>

    <!-- Cards: linha editorial com número grande -->
    <div class="flex flex-col" style="border-top: 1px solid rgba(201,168,60,0.2)">
      {servicos.map((s, i) => (
        <div
          class="group grid md:grid-cols-[80px_1fr_1.5fr_300px] gap-6 md:gap-6 items-start py-12 md:py-14 cursor-default"
          data-reveal
          style={`transition-delay:${i * 0.12}s; border-bottom: 1px solid rgba(201,168,60,0.2)`}
        >
          <!-- Número -->
          <div class="num-card font-display text-[2.5rem] font-light leading-none pt-1 transition-colors duration-500" style="color: rgba(201,168,60,0.3)">
            {s.num}
          </div>

          <!-- Nome -->
          <h3
            class="font-display font-light transition-colors duration-500"
            style="font-size: clamp(1.5rem, 2.5vw, 2.2rem); line-height: 1.15; white-space: pre-line; color: var(--ink)"
          >
            {s.nome}
          </h3>

          <!-- Descrição -->
          <p class="text-[0.88rem] leading-relaxed pt-1.5 md:border-l md:pl-6" style="color: var(--muted); border-color: var(--warm)">
            {s.desc}
          </p>

          <!-- Tag + imagem -->
          <div class="flex flex-col gap-4">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={s.img}
                alt={s.imgAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                style={s.imgPos ? `object-position: ${s.imgPos}` : ''}
              />
            </div>
            <p class="font-display italic text-sm font-light leading-snug" style="color: var(--terra)">
              {s.tag}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 flex" data-reveal>
      <a href="#agendar" class="btn-cta">
        <span class="btn-cta__icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
          </svg>
        </span>
        Agendar minha avaliação
      </a>
    </div>
  </div>
</section>

<style>
  .group:hover h3 { color: var(--terra) !important; }
  .group:hover .num-card { color: var(--terra) !important; }
</style>
