---
const formacao = [
  { ano: '2011', item: 'Início em Estética Dental' },
  { ano: '2012', item: 'Início em Ortodontia' },
  { ano: '2016', item: 'Início em Harmonização Orofacial' },
  { ano: 'UFSC', item: 'Graduação em Odontologia' },
  { ano: '25+',  item: 'Cursos de aperfeiçoamento e imersões nas três áreas' },
];
---

<section id="sobre" class="relative pt-48 pb-32 md:py-40 overflow-hidden" style="background: #0D1830">

  <!-- Número decorativo -->
  <div
    aria-hidden="true"
    class="absolute top-8 left-8 font-display text-[7rem] md:text-[11rem] leading-none select-none pointer-events-none font-light"
    style="color: #182448"
  >
    04
  </div>

  <!-- Símbolo de marca — espelha o número no canto oposto -->
  <div class="absolute top-6 right-6 md:top-10 md:right-10 pointer-events-none select-none" aria-hidden="true">
    <img
      src="/media/id-visual/33035.webp"
      alt=""
      class="w-28 md:w-44 h-auto opacity-[0.10]"
    />
  </div>

  <div class="max-w-7xl mx-auto px-8 md:px-12">

    <!-- Título acima -->
    <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-20 mb-20">
      <div data-reveal="left">
        <div class="rule" style="color: var(--clay)">Diferencial Profissional</div>
      </div>
      <div data-reveal>
        <h2
          class="font-display font-light"
          style="font-size: clamp(1.7rem, 3.2vw, 2.9rem); line-height: 1.1; max-width: 680px; color: #ffffff; font-weight: 300"
        >
          Uma visão completa da face — para resultados mais
          <em style="font-style:italic; color: var(--clay)"> precisos e naturais.</em>
        </h2>
      </div>
    </div>

    <!-- Layout: imagem + conteúdo -->
    <div class="grid md:grid-cols-[1fr_1fr] gap-16 md:gap-24 items-start">

      <!-- Imagem com frame decorativo -->
      <div class="relative" data-reveal="left">
        <div class="image-frame">
          <div class="overflow-hidden" style="aspect-ratio: 3/4;">
            <img
              src="/media/Facetune_04-03-2024-16-58-08.webp"
              alt="Dra. Tharita"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>

        <!-- Citação flutuante -->
        <div
          class="absolute -right-6 md:-right-10 bottom-12 border px-6 py-5 max-w-[220px] shadow-2xl"
          data-reveal="right"
          style="background: #131E3C; border-color: rgba(201,168,60,0.25); transition-delay: 0.3s"
        >
          <p class="font-display italic text-base font-light leading-snug" style="color: #ffffff">
            "Tratamentos pensados para valorizar quem você já é."
          </p>
          <div class="mt-3 w-8 h-px" style="background: var(--clay)"></div>
          <p class="mt-2 text-[0.62rem] tracking-widest uppercase" style="color: var(--clay)">Dra. Tharita</p>
        </div>
      </div>

      <!-- Texto + timeline -->
      <div class="flex flex-col gap-10" data-reveal style="transition-delay:0.2s">

        <p class="text-[0.95rem] leading-relaxed" style="color: rgba(245,243,239,0.85)">
          A combinação de experiência em Ortodontia, Estética Dental e Harmonização Orofacial permite um diagnóstico mais completo, um planejamento mais refinado — e resultados que realmente fazem sentido para o seu rosto.
        </p>

        <!-- Timeline de formação -->
        <div>
          <p class="text-[0.72rem] tracking-[0.2em] uppercase mb-8" style="color: rgba(245,243,239,0.55)">
            Formação & Trajetória
          </p>
          <div class="flex flex-col gap-0">
            {formacao.map((f, i) => (
              <div
                class="grid grid-cols-[60px_1fr] gap-6 py-5 border-b group"
                style={`border-color: rgba(245,243,239,0.08); transition-delay: ${0.25 + i * 0.08}s`}
                data-reveal
              >
                <span
                  class="timeline-ano font-display text-sm font-light pt-0.5 transition-colors duration-300"
                  style="color: rgba(201,168,60,0.9)"
                >
                  {f.ano}
                </span>
                <span class="text-[0.92rem] leading-relaxed" style="color: rgba(245,243,239,0.92)">
                  {f.item}
                </span>
              </div>
            ))}
          </div>
        </div>

        <div data-reveal style="transition-delay:0.65s">
          <a href="#agendar" class="btn-cta btn-cta--light">
            <span class="btn-cta__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
              </svg>
            </span>
            Agendar minha avaliação
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .group:hover .timeline-ano { color: var(--clay) !important; }
</style>
