---
---

<section id="agendar" class="relative pt-20 md:pt-28 pb-32 md:pb-40 overflow-hidden bg-parchment">

  <!-- Elemento tipográfico de fundo -->
  <div aria-hidden="true" class="absolute inset-0 flex items-end justify-end overflow-hidden pointer-events-none select-none">
    <span
      data-deco="Dra. Tharita"
      class="font-display font-light"
      style="font-size: clamp(8rem, 24vw, 22rem); line-height: 1; white-space: nowrap; color: rgba(168,136,40,0.1); transform: translate(-00%, 35%)"
    ></span>
  </div>

  <!-- Linha decorativa -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background: rgba(201,168,60,0.2)"></div>

  <div class="relative max-w-4xl mx-auto px-8 md:px-12 text-center">

    <p class="text-[0.68rem] tracking-[0.3em] uppercase mb-8 font-body" style="color: var(--muted)" data-reveal>
      Comece agora
    </p>

    <h2
      class="font-display font-light mb-8"
      style="font-size: clamp(2rem, 5.5vw, 4.8rem); line-height: 1.05; letter-spacing: -0.01em; color: var(--ink)"
      data-reveal
    >
      Pronta para a sua
      <em style="font-style:italic; color: var(--terra)"> melhor versão?</em>
    </h2>

    <p class="text-[0.92rem] leading-relaxed mb-14 max-w-xl mx-auto" style="color: var(--muted); transition-delay:0.15s" data-reveal>
      Se você busca resultados naturais, elegantes e personalizados para o seu rosto — este é o lugar certo para você. Agende uma avaliação e descubra o que é possível.
    </p>

    <!-- WhatsApp CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-reveal style="transition-delay:0.25s">
      <a
        href="https://wa.me/5548996953634?text=Olá!%20Gostaria%20de%20agendar%20uma%20avaliação."
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta"
      >
        <span class="btn-cta__icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: var(--cream)">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </span>
        Agendar pelo WhatsApp
      </a>
    </div>

    <p class="mt-8 text-[0.7rem] tracking-widest uppercase" style="color: var(--muted)" data-reveal>
      Resposta rápida
    </p>
  </div>
</section>
