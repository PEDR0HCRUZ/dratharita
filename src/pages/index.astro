---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problema from '../components/Problema.astro';
import Servicos from '../components/Servicos.astro';
import Sobre from '../components/Sobre.astro';
import Resultados from '../components/Resultados.astro';
import AntesDepois from '../components/AntesDepois.astro';
import Tecnologia from '../components/Tecnologia.astro';
import Beneficios from '../components/Beneficios.astro';
import QuebradaDeObjecao from '../components/QuebradaDeObjecao.astro';
import Depoimentos from '../components/Depoimentos.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Problema />
    <Servicos />
    <Sobre />
    <Resultados />
    <AntesDepois />
    <Tecnologia />
    <Beneficios />
    <QuebradaDeObjecao />
    <Depoimentos />
    <CTA />
  </main>
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';

  // ── Animação GSAP nos botões btn-cta ────────────────────────────
  document.querySelectorAll('.btn-cta').forEach((btn) => {
    const svg = btn.querySelector('.btn-cta__icon svg');
    if (!svg) return;

    const animateForward = () => {
      gsap.killTweensOf(svg);
      gsap.to(svg, {
        x: 12, y: -12, opacity: 0,
        duration: 0.18, ease: 'power2.in',
        onComplete: () => {
          gsap.set(svg, { x: -12, y: 12, opacity: 0 });
          gsap.to(svg, { x: 0, y: 0, opacity: 1, duration: 0.22, ease: 'power2.out' });
        },
      });
    };

    btn.addEventListener('mouseenter', animateForward);
    btn.addEventListener('mouseleave', animateForward);
  });

  // ── Animação GSAP no botão do nav (horizontal) ──────────────────
  const navCta = document.getElementById('nav-cta');
  const navIcon = document.getElementById('nav-cta-icon');
  if (navCta && navIcon) {
    const animateNavIcon = () => {
      gsap.killTweensOf(navIcon);
      gsap.to(navIcon, {
        x: 16, opacity: 0,
        duration: 0.18, ease: 'power2.in',
        onComplete: () => {
          gsap.set(navIcon, { x: -16, opacity: 0 });
          gsap.to(navIcon, { x: 0, opacity: 1, duration: 0.22, ease: 'power2.out' });
        },
      });
    };
    navCta.addEventListener('mouseenter', animateNavIcon);
    navCta.addEventListener('mouseleave', animateNavIcon);
  }

  // ── IntersectionObserver global para [data-reveal] ──────────────
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));

  // ── Counter animation para [data-counter] ────────────────────────
  const counterEls = document.querySelectorAll('[data-counter]');
  const counterIo = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.counter || '0', 10);
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        counterIo.unobserve(el);
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 1.8,
          ease: 'power2.out',
          onUpdate() {
            el.textContent = prefix + Math.round(obj.val) + suffix;
          },
        });
      });
    },
    { threshold: 0.4 }
  );
  counterEls.forEach((el) => counterIo.observe(el));

  // ── Smooth anchor scroll com offset da nav ──────────────────────
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = (anchor as HTMLAnchorElement).getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      const offset = 80;
      const top = target.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  });
</script>
